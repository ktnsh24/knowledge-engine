# =============================================================================
# Knowledge Engine — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Cloud provider: local | aws | azure
CLOUD_PROVIDER=local
APP_ENV=dev

# =============================================================================
# Donkey Analogy (always on — baked into system prompts)
# =============================================================================
DONKEY_ANALOGY_ENABLED=true

# =============================================================================
# LLM Configuration
# =============================================================================

# Local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# AWS Bedrock
AWS_REGION=eu-central-1
AWS_BEDROCK_LLM_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
AWS_BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# AWS credentials — use AWS_PROFILE=personal, never hardcode keys
AWS_PROFILE=personal

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================================
# Vector Store Configuration
# =============================================================================

# Local (ChromaDB)
CHROMA_PERSIST_PATH=./data/chroma

# AWS (DynamoDB brute-force cosine — same pattern as rag-chatbot)
DYNAMODB_VECTORS_TABLE=knowledge-engine-vectors

# Azure (Azure AI Search)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-key-here
AZURE_SEARCH_INDEX=knowledge-engine

# =============================================================================
# Graph Store Configuration
# =============================================================================

# Local (Neo4j via Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge123

# AWS (DynamoDB adjacency list — no extra service needed)
DYNAMODB_GRAPH_TABLE=knowledge-engine-graph

# Azure (Cosmos DB NoSQL with adjacency list)
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=your-key-here
COSMOS_DB_DATABASE=knowledge-engine
COSMOS_DB_GRAPH_CONTAINER=graph

# =============================================================================
# Source Repositories (docs to ingest)
# =============================================================================
SOURCE_REPOS_PATH=../
SOURCE_REPOS=rag-chatbot,ai-gateway,ai-agent,ai-multi-agent,mcp-server,ai-engineering-field-guide
INCLUDE_PATTERNS=**/*.md,**/*.txt
EXCLUDE_PATTERNS=**/node_modules/**,**/.venv/**,**/site/**,**/__pycache__/**

# =============================================================================
# Wiki Output
# =============================================================================
WIKI_OUTPUT_PATH=./wiki-output
WIKI_REBUILD_ON_CHANGE=true

# =============================================================================
# API Configuration
# =============================================================================
API_PORT=8200
API_KEYS_ENABLED=false
MASTER_API_KEY=dev-key-change-in-production

# =============================================================================
# Evaluation
# =============================================================================
EVAL_ENABLED=true
EVAL_GOLDEN_QUESTIONS_PATH=./scripts/golden-questions.yaml

# =============================================================================
# Config-tuning labs (Tier 1–5)
# See docs/hands-on-labs/hands-on-labs-config-tuning.md
# App code does not yet read these — wiring them up is part of running each lab.
# =============================================================================

# Tier 1 — Essential
RAG_CHUNK_SIZE=500              # Tokens per chunk (sweep: 200/500/1000)
RAG_CHUNK_OVERLAP=100           # Token overlap between chunks (sweep: 0/100/200)
RAG_TOP_K=5                     # How many chunks to retrieve per query (sweep: 1/3/5/10)
LLM_TEMPERATURE=0.0             # Sampling temperature (sweep: 0.0/0.3/0.7)
SYSTEM_PROMPT_MODE=strict       # strict|lax — controls hallucination strictness
EMBEDDING_DIMENSIONS=1024       # 384/768/1024 — must match embedding model

# Tier 2 — Quality
RERANKER_ENABLED=false          # Re-score retrieved chunks before sending to LLM
RERANKER_MODEL=bge-reranker-base
HYBRID_SEARCH_ENABLED=false     # Combine vector search + BM25 keyword search
HYBRID_ALPHA=0.5                # 0.0=pure keyword, 1.0=pure vector
LLM_MAX_TOKENS=1024             # Max output tokens (sweep: 256/1024/4096)
DISTANCE_METRIC=cosine          # cosine|l2|dot

# Tier 3 — HNSW vector-store tuning
HNSW_M=16                       # Connections per node (sweep: 8/16/32)
HNSW_EF_CONSTRUCTION=200        # Build-time search depth (sweep: 100/200/400)
HNSW_EF_SEARCH=64               # Query-time search depth (sweep: 32/64/128/256)

# Tier 4 — Retrieval strategy
QUERY_REWRITING_ENABLED=false   # Use LLM to rewrite vague queries before search
MULTI_QUERY_COUNT=1             # Generate N query variants and merge (sweep: 1/3/5)
METADATA_FILTERS=               # e.g. source=docs,date>2024-01-01
CHUNK_STRATEGY=fixed            # fixed|semantic|sentence|markdown-aware

# Tier 5 — Evaluation knobs
EVAL_MODE=rule_based            # rule_based|llm_judge
EVAL_FAITHFULNESS_THRESHOLD=0.5 # Min % of grounded sentences to pass (sweep: 0.3/0.5/0.8)
EVAL_KEYWORD_OVERLAP_PCT=0.5    # Strictness of keyword matching in faithfulness scoring
